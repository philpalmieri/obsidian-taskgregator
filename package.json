  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.20.0",
    "obsidian": "latest",
    "typescript": "^5.4.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/philpalmieri/obsidian-taskgregator.git"
  },
  "bugs": {
    "url": "https://github.com/philpalmieri/obsidian-taskgregator/issues"
